pipeline {
    agent any

    environment {
        APP_NAME = "subscription-service"
        VERSION = "1.0.0"
        GROUP_PATH = "tn/esprit/subscription-service"
        NEXUS_URL = "http://nexus:8081/repository/maven-releases"
        DOCKER_IMAGE = "subscription-service:1.0.0"
    }

    stages {

        stage('Download JAR from Nexus') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'nexus-cred',
                    usernameVariable: 'NEXUS_USER',
                    passwordVariable: 'NEXUS_PASS'
                )]) {

                    sh '''
                    echo "Downloading JAR from Nexus..."

                    curl --fail --location \
                    -u $NEXUS_USER:$NEXUS_PASS \
                    -o app.jar \
                    $NEXUS_URL/$GROUP_PATH/$VERSION/$APP_NAME-$VERSION.jar

                    ls -lh app.jar
                    '''
                }
            }
        }

        stage('Check JAR') {
            steps {
                sh '''
                echo "Checking JAR..."

                if [ ! -f app.jar ] || [ ! -s app.jar ]; then
                    echo "ERROR: app.jar missing or empty"
                    exit 1
                fi

                echo "JAR OK"
                '''
            }
        }

        stage('Build Docker Image') {
            steps {
                sh '''
                echo "Building Docker image..."

                docker build -t $DOCKER_IMAGE .

                echo "Docker image built"
                '''
            }
        }

        stage('Run Docker Container') {
            steps {
                sh '''
                echo "Running container..."

                docker rm -f $APP_NAME || true

                docker run -d \
                  --name $APP_NAME \
                  --network devops-net \
                  -p 8085:8084 \
                  $DOCKER_IMAGE

                sleep 10

                docker ps | grep $APP_NAME
                '''
            }
        }

        stage('Deploy Kubernetes') {
            steps {
                sh '''
                echo "Checking kubectl..."

                if ! command -v kubectl >/dev/null 2>&1; then
                    echo "Installing kubectl..."
                    curl -LO https://dl.k8s.io/release/v1.29.0/bin/linux/amd64/kubectl
                    chmod +x kubectl
                    mv kubectl /usr/local/bin/
                fi

                kubectl apply -f k8s/deployment.yaml
                kubectl apply -f k8s/service.yaml
                '''
            }
        }

    post {

        success {
            echo 'CD SUCCESS'
        }

        failure {
            echo ' xxCD FAILED'
        }

        always {
            cleanWs()
        }
    }
}