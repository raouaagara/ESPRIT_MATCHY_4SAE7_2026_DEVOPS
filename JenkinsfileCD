pipeline {
    agent any

    environment {
        APP_NAME = "subscription-service"
        VERSION = "1.0.0"
        GROUP_PATH = "tn/esprit/subscription-service"

        NEXUS_URL = "http://nexus:8081/repository/maven-releases"

        DOCKER_IMAGE = "subscription-service:1.0.0"
    }

    stage('Download JAR from Nexus') {
        steps {

            withCredentials([usernamePassword(
                credentialsId: 'nexus-cred',
                usernameVariable: 'NEXUS_USER',
                passwordVariable: 'NEXUS_PASS'
            )]) {

                sh """
                echo "Downloading JAR from Nexus..."

                curl --fail --location \
                -u \$NEXUS_USER:\$NEXUS_PASS \
                -o app.jar \
                ${NEXUS_URL}/${GROUP_PATH}/${VERSION}/${APP_NAME}-${VERSION}.jar

                echo "JAR downloaded successfully"

                ls -lh app.jar
                """
            }
        }
    }
        stage('Check JAR') {
            steps {

                sh '''
                echo "Checking JAR file..."

                if [ ! -f app.jar ]; then
                    echo "ERROR: app.jar not found"
                    exit 1
                fi

                if [ ! -s app.jar ]; then
                    echo "ERROR: app.jar is empty"
                    exit 1
                fi

                ls -lh app.jar

                echo "JAR OK"
                '''
            }
        }

        stage('Build Docker Image') {
            steps {

                sh """
                echo "Building Docker image..."

                docker build -t ${DOCKER_IMAGE} .

                echo "Docker image created"
                """
            }
        }

        stage('Run Docker Container (test)') {
            steps {

                sh """
                echo "Running Docker container..."

                docker rm -f ${APP_NAME} || true

                docker run -d \
                    --name ${APP_NAME} \
                    --network devops-net \
                    -p 8085:8084 \
                    ${DOCKER_IMAGE}

                echo "Waiting container startup..."
                sleep 10

                docker ps | grep ${APP_NAME}

                echo "Container running successfully"
                """
            }
        }

        stage('Deploy to Kubernetes (kubeadm)') {
            steps {

                sh """
                echo "Deploying to Kubernetes..."

                kubectl apply -f k8s/deployment.yaml

                kubectl apply -f k8s/service.yaml

                kubectl rollout status deployment/${APP_NAME} --timeout=120s

                echo "Kubernetes deployment successful"
                """
            }
        }
    }

    post {

        success {
            echo "CD SUCCESS: Docker + Kubernetes deployed"
        }

        failure {
            echo "CD FAILED"
        }

        always {
            cleanWs()
        }
    }
}