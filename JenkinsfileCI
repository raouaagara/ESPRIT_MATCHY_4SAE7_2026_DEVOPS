pipeline {
    agent any

    tools {
        maven 'Maven'
        jdk 'JDK21'
    }

    environment {
        JAVA_HOME = '/opt/java/openjdk'
        PATH = "${JAVA_HOME}/bin:${env.PATH}"

        SONARQUBE = 'sonarqube-server'

        // IMPORTANT : CI → SNAPSHOT repo
        NEXUS_REPO = 'http://nexus:8081/repository/maven-snapshots/'
    }

    triggers {
        pollSCM('H/2 * * * *')
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build + Test') {
            steps {
                sh 'mvn clean verify'
            }
            post {
                always {
                    junit allowEmptyResults: true,
                          testResults: 'target/surefire-reports/*.xml'
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('sourour') {
                    sh 'mvn sonar:sonar'
                }
            }
        }

        stage('Package') {
            steps {
                sh 'mvn clean package -DskipTests'
            }
        }

        stage('Deploy to Nexus (Snapshots)') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'nexus-cred',
                    usernameVariable: 'USER',
                    passwordVariable: 'PASS'
                )]) {

                    writeFile file: 'settings.xml', text: """
<settings>
  <servers>
    <server>
      <id>nexus</id>
      <username>${USER}</username>
      <password>${PASS}</password>
    </server>
  </servers>
</settings>
"""

                    sh "mvn -s settings.xml deploy -DskipTests"
                }
            }
        }
    }

    post {
        success {
            echo "✅ CI SUCCESS : Build + Test + Sonar + Nexus OK"

            echo "🚀 Triggering CD Pipeline..."

            build job: 'CD-Pipeline', wait: false
        }

        failure {
            echo "❌ CI FAILED"
        }

        always {
            cleanWs()
        }
    }
}