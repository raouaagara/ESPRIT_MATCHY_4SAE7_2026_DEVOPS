pipeline {
    agent any

    tools {
        maven 'Maven'
        jdk 'JDK21'
    }

    environment {
        JAVA_HOME = '/opt/java/openjdk'
        PATH = "${JAVA_HOME}/bin:${env.PATH}"

        SONARQUBE = 'sonarqube-server'

        NEXUS_REPO = 'http://192.168.183.128:8081/repository/maven-releases/'
    }

    triggers {
        pollSCM('H/2 * * * *')   // ou webhook GitHub si configuré
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build + Test') {
            steps {
                sh 'mvn clean verify'
            }
            post {
                always {
                    junit allowEmptyResults: true, testResults: 'target/surefire-reports/*.xml'
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('sourour') {
                    sh 'mvn sonar:sonar'
                }
            }
        }

        stage('Package') {
            steps {
                sh 'mvn clean package -DskipTests'
            }
        }

        stage('Deploy JAR to Nexus') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'nexus-cred',
                    usernameVariable: 'USER',
                    passwordVariable: 'PASS'
                )]) {

                    writeFile file: 'settings.xml', text: """
<settings>
  <servers>
    <server>
      <id>nexus</id>
      <username>${USER}</username>
      <password>${PASS}</password>
    </server>
  </servers>
</settings>
"""

                    sh "mvn -s settings.xml deploy -DskipTests"
                }
            }
        }
    }

    post {
        success {
            echo "✅ CI SUCCESS : Build + Test + Sonar + Nexus OK"
        }

        failure {
            echo "❌  FAILED"
        }
    }
}