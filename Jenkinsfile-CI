pipeline {
    agent any

    triggers {
        pollSCM('H/2 * * * *')
    }

    environment {
        SONAR_SERVER = 'sonar-server'
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build & Test') {
            steps {
                sh '''
                    if [ -f "mvnw" ]; then
                        chmod +x mvnw
                        ./mvnw clean verify
                    else
                        mvn clean verify
                    fi
                '''
            }

           post {
               always {
                   junit testResults: 'target/surefire-reports/*.xml', allowEmptyResults: true
               }
           }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv("${SONAR_SERVER}") {
                    sh '''
                        if [ -f "mvnw" ]; then
                            ./mvnw sonar:sonar
                        else
                            mvn sonar:sonar
                        fi
                    '''
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

    }

    post {
        success {
            echo "✅ CI OK - code validé"
        }
        failure {
            echo "❌ CI FAILED - code rejeté"
        }
    }
}